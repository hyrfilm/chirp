{
  "name": "degaming",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest --coverage",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "node scripts/migrate.ts latest",
    "db:migrate:up": "node scripts/migrate.ts up",
    "db:migrate:down": "node scripts/migrate.ts down",
    "db:migrate:reset": "node scripts/migrate.ts reset",
    "db:clear": "npm run db:migrate:reset",
    "db:seed": "npm run db:clear && npm run db:migrate && npm run db:seed:load",
    "db:seed:load": "node scripts/seed.ts",
    "db:reset:seed": "npm run db:seed",
    "build:all": "npm run build && npm run build:docker",
    "build:docker": "docker buildx build -f docker/Dockerfile docker -t postgres:18"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fast-check": "^4.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
